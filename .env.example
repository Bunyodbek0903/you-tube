# Anti-captcha API kaliti (captcha yechish uchun majburiy)
ANTICAPTCHA_API_KEY=your_anticaptcha_api_key_here

# Proxy sozlamalari
USE_PROXY=False
USE_PROXY_API=True
PROXY_LIST_FILE=proxies.txt

# ProxyScrape API sozlamalari
PROXY_TYPE=http
PROXY_TIMEOUT=10000
PROXY_SSL=all
PROXY_ANONYMITY=all
PROXY_COUNTRY=all
PROXY_CACHE_DURATION=300

# Browser sozlamalari
HEADLESS=False
BROWSER_TIMEOUT=30

# Kechikish sozlamalari (sekundlarda)
MIN_DELAY=2
MAX_DELAY=5

# Fayl yo'llari
ACCOUNTS_FILE=accounts.txt
RESULTS_FILE=results.json
LOG_FILE=youtube_automation.log
USER_AGENT_FILE=user_agents.txt

# Captcha sozlamalari
CAPTCHA_TIMEOUT=60

# Qayta urinish sozlamalari
MAX_RETRIES=3
RETRY_DELAY=10