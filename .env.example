# Anti-captcha API key (required for captcha solving)
ANTICAPTCHA_API_KEY=your_anticaptcha_api_key_here

# Proxy settings
USE_PROXY=False
USE_PROXY_API=True
PROXY_LIST_FILE=proxies.txt

# ProxyScrape API settings
PROXY_TYPE=http
PROXY_TIMEOUT=10000
PROXY_SSL=all
PROXY_ANONYMITY=all
PROXY_COUNTRY=all
PROXY_CACHE_DURATION=300

# Browser settings
HEADLESS=False
BROWSER_TIMEOUT=30

# Delay settings (seconds)
MIN_DELAY=2
MAX_DELAY=5

# File paths
ACCOUNTS_FILE=accounts.txt
RESULTS_FILE=results.json
LOG_FILE=youtube_automation.log
USER_AGENT_FILE=user_agents.txt

# Captcha settings
CAPTCHA_TIMEOUT=60

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=10